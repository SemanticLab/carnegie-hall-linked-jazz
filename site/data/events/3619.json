4193", "name": "Conrad Gozzo", "qid": "Q952513", "roles": ["trumpet"]}, {"id": "36948", "name": "Irwin \"Marky\" Markowitz", "qid": null, "roles": ["trumpet"]}, {"id": "42177", "name": "Mickey Folus", "qid": null, "roles": ["tenor_saxophone"]}, {"id": "43393", "name": "Flip Phillips", "qid": "Q485264", "roles": ["tenor_saxophone"]}, {"id": "56703", "name": "Billy Bauer", "qid": "Q345807", "roles": ["guitar"]}, {"id": "57108", "name": "Woody Herman", "qid": "Q349357", "roles": ["clarinet"]}, {"id": "58040", "name": "Ed Kiefer", "qid": null, "roles": ["trombone"]}, {"id": "64714", "name": "Ralph Pfeffner", "qid": null, "roles": ["trombone"]}, {"id": "64721", "name": "Sam Rubinowitch", "qid": null, "roles": ["baritone_saxophone"]}]}], "quotes": [{"speaker": "Woody Herman", "qid": "Q349357", "text": "And -- but basically, it was his music, as it should have been. And we learned to play the music, and presented it at Carnegie Hall in 1946, at our first jazz concert. And the critique was quite broad, some of it with great gusto and enjoyment and some of it couldn't understand what it was about and so consequently I would say it would remind me of some of the things that still happen.", "caption": "Woody Herman's first jazz concert at Carnegie Hall in 1946", "conf": "high", "first_person": true, "doc_title": "52220_Woody Herman oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/52220/"}], "featured_people": [{"qid": "Q345807", "id": "56703", "name": "Billy Bauer"}, {"qid": "Q598368", "id": "14086", "name": "Chubby Jackson"}, {"qid": "Q952513", "id": "34193", "name": "Conrad Gozzo"}, {"qid": "Q1239247", "id": "20972", "name": "Don Lamond"}, {"qid": "Q485264", "id": "43393", "name": "Flip Phillips"}, {"qid": "Q1701487", "id": "31211", "name": "John Barrows"}, {"qid": "Q1700769", "id": "23186", "name": "John LaPorta"}, {"qid": "Q301791", "id": "28619", "name": "Pete Candoli"}, {"qid": "Q1966681", "id": "1759", "name": "R