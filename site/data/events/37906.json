e": "Lynn Hope", "qid": "Q1878862", "roles": ["tenor_saxophone"]}]}, {"label": "Wheel of Fortune", "work": "Wheel of Fortune", "composer": "Bennie Benjamin", "performers": [{"id": "39974", "name": "Dinah Washington", "qid": "Q229322", "roles": ["vocalist"]}]}, {"label": "Cheek to Cheek", "work": "Cheek to Cheek", "composer": "Irving Berlin", "performers": [{"id": "9975", "name": "Eddie Heywood", "qid": "Q924783", "roles": ["piano"]}]}, {"label": "The Swing", "work": "The Swing", "composer": null, "performers": [{"id": "2665", "name": "Slide Hampton", "qid": "Q1369035", "roles": ["trombone"]}, {"id": "124529", "name": "Duke Hampton Boy and Girl Band", "qid": null, "roles": ["jazz_ensemble"]}, {"id": "124530", "name": "Duke Hampton", "qid": null, "roles": ["band_leader"]}, {"id": "124531", "name": "Aletra Hampton", "qid": "Q55284732", "roles": ["piano"]}]}, {"label": "Everything I Have Is Yours", "work": "Everything I Have Is Yours", "composer": "Burton Lane", "performers": [{"id": "17474", "name": "Billy Eckstine", "qid": "Q545464", "roles": ["vocalist"]}]}, {"label": "Selection (unspecified)", "work": "Selection (unspecified)", "composer": null, "performers": [{"id": "62536", "name": "Paul Bascomb Band", "qid": null, "roles": ["jazz_ensemble"]}, {"id": "62537", "name": "Paul Bascomb", "qid": "Q364229", "roles": ["tenor_saxophone"]}]}, {"label": "I Can't Lose with the Stuff I Use", "work": "I Can't Lose with the Stuff I Use", "composer": "Lester Williams", "performers": [{"id": "124532", "name": "Lester Williams", "qid": null, "roles": ["guitar", "vocalist"]}]}, {"label": "No No Nanette: Tea for Two", "work": "No No Nanette: Tea for Two", "composer": "Vincent Youmans", "performers": [{"id": "124533", "name": "Paula DuPree", "qid": null, "roles": ["piano"]}]}, {"label": "All of Me", "work": "All of Me", "composer": "Gerald Marks", "performers": [{"id": "124534", "name": "Laura Lynn", "qid": null, "roles": ["vocalist"]}]}, {"label": "You Better Go Now", "work": "You Better Go Now", "composer": "Irvin Graham", "performers": [{"id": "124535", "name": "Aretta LeMarre", "qid": null, "roles": ["vocalist"]}]}, {"label": "Sweet Lorraine", "work": "Sweet Lorraine", "composer": "Cliff Burwell", "performers": [{"id": "35235", "name": "Nat King Cole", "qid": "Q137042", "roles": ["piano", "vocalist"]}]}], "quotes": [{"speaker": "Slide Hampton", "qid": "Q1369035", "text": "In 1952, music took you to Carnegie Hall with the Hampton band. At that point, you had been performing trombone professionally, touring. I think of it as barnstorming. I’d like you to respond to that. But I want you to tell the record, how the Hampton – not the Lionel Hampton band, but the Hampton family band – got to Carnegie Hall in 1952.", "caption": "Hampton family band's 1952 Carnegie Hall debut", "conf": "high", "first_person": false, "doc_title": "Slide Hampton — Smithsonian Jazz Oral History", "collection": "si", "url": "https://amhistory.si.edu/jazz/Hampton-Slide/Hampton_Slide_Transcript.pdf"}, {"speaker": "Slide Hampton", "qid": "Q1369035", "text": "Besides practicing, there was a contest that Lionel Hampton’s band was set up to do this. They were set up to do this, and part of the attraction to wanting to win this competition was that you were going to get to play – open the show for Lionel Hampton’s band. We got votes and got people to vote for us. We got enough votes to win this contest. We won it, and we played Carnegie Hall, opening the show for Lionel Hampton’s band.", "caption": "Winning a contest to open for Lionel Hampton at Carnegie Hall", "conf": "medium", "first_person": true, "doc_title": "Slide Hampton — Smithsonian Jazz Oral History", "collection": "si", "url": "https://amhistory.si.edu/jazz/Hampton-Slide/Hampton_Slide_Transcript.pdf"}, {"speaker": "Slide Hampton", "qid": "Q1369035", "text": "When you played at Carnegie Hall in ’52, could you visualize yourself ultimately being in the Lionel Hampton band?", "caption": "Slide Hampton's 1952 Carnegie Hall debut", "conf": "high", "first_person": false, "doc_title": "Slide Hampton — Smithsonian Jazz Oral History", "collection": "si", "url": "https://amhistory.si.edu/jazz/Hampton-Slide/Hampton_Slide_Transcript.pdf"}], "featured_people": [{"qid": "Q55284732", "id": "124531", "name": "Aletra Hampton"}, {"qid": "Q545464", "id": "17474", "name": "Billy Eckstine"}, {"qid": "Q229322", "id": "39974", "name": "Dinah Washington"}, {"qid": "Q924783", "id": "9975", "name": "Eddie Heywood"}, {"qid": "Q313525", "id": "41532", "name": "Lionel Hampton"}, {"qid": "Q1878862", "id": "62540", "name": "Lynn Hope"}, {"qid": "Q558933", "id": "41231", "name": "Milton Berle"}, {"qid": "Q137042", "id": "35235", "name": "Nat King Cole"}, {"qid": "Q364229", "id": "62537", "name": "Paul Bascomb"}, {"qid": "Q1369035", "id": "2665", "name": "Slide Hampton"}, {"qid": "Q2302292", "id": "124528", "name": "Sonny Parker"}, {"qid": "Q316706", "id": "67127", "name": "Sugar Ray Robinson"}, {"qid": "Q730199", "id": "29736", "name": "Willie Bryant"}]}