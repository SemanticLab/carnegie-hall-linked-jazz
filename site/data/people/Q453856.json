{"qid": "Q453856", "name": "Kay Davis", "match_basis": "qid", "ch_id": "36092", "ch_uri": "http://data.carnegiehall.org/names/36092", "birth": "1920", "death": "2012", "description": "Jazz singer (1920–2012)", "abstract": "Kathryn Elizabeth Wimp, known professionally as Kay Davis (December 5, 1920 – January 27, 2012 in Apopka, Florida), was an American jazz singer who performed with the Duke Ellington orchestra. Davis was born in Evanston, Illinois, and attended Evanston Township High School.", "wp_title": "Kay Davis", "image": "img/p/Q453856.jpg", "is_interviewee": false, "lj_docs": 9, "lj_mentions": 18, "lj_node": "wd:Q453856", "interviews": [], "concerts": [{"id": "33307", "date": "1944-12-19", "label": "Duke Ellington and His Orchestra", "venue": "Main Hall", "roles": ["vocalist"], "works": [{"t": "Creole Love Call", "c": "Duke Ellington", "w": "42713"}]}, {"id": "5235", "date": "1946-01-04", "label": "Duke Ellington and His Orchestra", "venue": "Main Hall", "roles": ["vocalist"], "works": [{"t": "Transbluency", "c": "Duke Ellington", "w": "43862"}]}, {"id": "24774", "date": "1946-11-23", "label": "Duke Ellington and His Orchestra", "venue": "Main Hall", "roles": ["vocalist"], "works": [{"t": "The Beautiful Indians", "c": "Duke Ellington", "w": "43781"}]}, {"id": "43939", "date": "1946-11-24", "label": "Duke Ellington and His Orchestra", "venue": "Main Hall", "roles": ["vocalist"], "works": [{"t": "The Beautiful Indians", "c": "Duke Ellington", "w": "43781"}]}, {"id": "30809", "date": "1947-12-26", "label": "Duke Ellington and His Orchestra", "venue": "Main Hall", "roles": ["vocalist"], "works": [{"t": "On a Turquoise Cloud", "c": "Duke Ellington", "w": "8860"}]}, {"id": "30810", "date": "1947-12-27", "label": "Duke Ellington and His Orchestra", "venue": "Main Hall", "roles": ["vocalist"], "works": [{"t": "On a Turquoise Cloud", "c": "Duke Ellington", "w": "8860"}]}, {"id": "18966", "date": "1948-11-13", "label": "Duke Ellington and His Orchestra", "venue": "Main Hall", "roles": ["vocalist"], "works": [{"t": "Creole Love Call", "c": "Duke Ellington", "w": "42713"}, {"t": "Don't Blame Me", "c": "Jimmy McHugh", "w": "34870"}, {"t": "Lush Life", "c": "Billy Strayhorn", "w": "31935"}]}], "works_created": [], "quotes": [], "about_quotes": [{"speaker": "Maxine Sullivan", "relation": "knows of", "confidence": 0.9, "evidence": "I had mentioned to Maxine that in a sense these go back to the singer who sang with Duke Ellington just after World War II, Kay Davis... And I just wanted to add that Maxine spoke of her very approvingly.", "doc_title": "61529_Maxine Sullivan oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/61529/"}, {"speaker": "Cootie Williams", "relation": "knows of", "confidence": 0.9, "evidence": "Interviewer mentions Kay Davis in relation to 'he' (Cootie Williams), Interviewee confirms with 'Yeah' and 'Uh-huh'.", "doc_title": "56712_Cootie Williams oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/56712/"}, {"speaker": "Patricia Willard", "relation": "collaborated with", "confidence": 0.9, "evidence": "we did one thing, one tune we did, transbluency. Now, this was done by Duke and Kay Davis.", "doc_title": "67250_John Collins oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/67250/"}, {"speaker": "Sonny Greer", "relation": "knows of", "confidence": 0.9, "evidence": "Kay Davis, little girl who married a big lawyer in Chicago. She sang all them high notes.", "doc_title": "52263_Sonny Greer oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/52263/"}, {"speaker": "Patricia Willard", "relation": "knows of", "confidence": 0.9, "evidence": "Oh, I remember Kay Davis and Cheryl -- she's around here somewhere.", "doc_title": "61531_Juan Tizol oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/61531/"}, {"speaker": "Quentin Jackson", "relation": "knows of", "confidence": 0.9, "evidence": "And he wrote 'Turquoise Cloud' for Kay Davis to sing, you know.", "doc_title": "61539_Butter Jackson oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/61539/"}]}