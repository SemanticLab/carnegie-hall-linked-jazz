", "date": "1985-09-10", "label": "Frank Sinatra, Singer", "venue": "Main Hall", "roles": ["guitar"], "works": [{"t": "Selections (unspecified)", "c": null, "w": "104450"}]}, {"id": "41985", "date": "1985-09-11", "label": "Frank Sinatra, Singer", "venue": "Main Hall", "roles": ["guitar"], "works": [{"t": "Selections (unspecified)", "c": null, "w": "104450"}]}, {"id": "41986", "date": "1985-09-12", "label": "Frank Sinatra, Singer", "venue": "Main Hall", "roles": ["guitar"], "works": [{"t": "Selections (unspecified)", "c": null, "w": "104450"}]}, {"id": "41987", "date": "1985-09-13", "label": "Frank Sinatra, Singer", "venue": "Main Hall", "roles": ["guitar"], "works": [{"t": "Selections (unspecified)", "c": null, "w": "104450"}]}, {"id": "41988", "date": "1985-09-14", "label": "Frank Sinatra, Singer", "venue": "Main Hall", "roles": ["guitar"], "works": [{"t": "Selections (unspecified)", "c": null, "w": "104450"}]}], "works_created": [], "quotes": [], "about_quotes": [{"speaker": "Bucky Pizzarelli", "relation": "collaborated with", "confidence": 1.0, "evidence": "My favorite records are — the first duo I made was with Tony Mottola... we made a couple of beautiful records together", "doc_title": "Bucky Pizzarelli interviewed by Monk Rowe, Aspen, Colorado, October 11, 1997 [interview 1 of 2]", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/bucky-pizzarelli-interviewed-monk-rowe-aspen-colorado-october-11-1997-interview"}, {"speaker": "John Abercrombie", "relation": "influenced by", "confidence": 0.9, "evidence": "I heard Tony Mottola play on the “Perry Como Show.” ... I asked my guitar teacher, I said, “Can you show me what these pretty chords are that Tony Mottola plays?” ... So that kind of got me into wanting to play something else.", "doc_title": "John Abercrombie interviewed by Monk Rowe, Clinton, New York, April 19, 2001", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/john-abercrombie-interviewed-monk-rowe-clinton-new-york-april-19-2001"}, {"speaker": "Skitch Henderson", "relation": "in music group with", "confidence": 0.9, "evidence": "Tony Mottola and Bucky, all of those guys, they rotated the schedule unto themselves... Mottola was the looker... I had Al Klink in that band... I'm so lucky to have had that.", "doc_title": "Skitch Henderson interviewed by Monk Rowe, New Milford, Connecticut, October 31, 1998", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/skitch-henderson-interviewed-monk-rowe-new-milford-connecticut-october-31-1998"}, {"speaker": "Lou Pallo", "relation": "knows of", "confidence": 0.9, "evidence": "I really have to mention Tony Mottola, one of my favorites... But Tony Mottola was the king to me. I just loved the way he played.", "doc_title": "Lou Pallo interviewed by Monk Rowe, New York City, New York, January 14, 2007", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/lou-pallo-interviewed-monk-rowe-new-york-city-new-york-january-14-2007"}, {"speaker": "Bucky Pizzarelli", "relation": "in music group with", "confidence": 0.9, "evidence": "Mundell Lowe, Billy Bauer, Chuck Wayne, Tony Mottola, Al Caiola — all great players, playing three chords.", "doc_title": "Bucky Pizzarelli interviewed by Monk Rowe, Clinton, New York, May 23, 2003 [interview 2 of 2]", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/bucky-pizzarelli-interviewed-monk-rowe-clinton-new-york-may-23-2003-interview-2"}, {"speaker": "Ruth & Bucky Pizzarelli", "relation": "collaborated with", "confidence": 0.9, "evidence": "So Tony Mottola and I got together and we made up an Italian medley.", "doc_title": "Ruth & Bucky Pizzarelli interviewed by Monk Rowe, Saddle River, New Jersey, January 19, 2015", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/ruth-bucky-pizzarelli-interviewed-monk-rowe-saddle-river-new-jersey-january-19"}]}