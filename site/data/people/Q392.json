3"}, {"t": "Forever Young", "w": "97906"}, {"t": "Tombstone Blues", "w": "103730"}, {"t": "It's All Over Now, Baby Blue", "w": "103726"}, {"t": "Blowin' in the Wind", "w": "73962"}, {"t": "Talkin' John Birch Paranoid Blues", "w": "116525"}, {"t": "Seven Curses", "w": "116528"}, {"t": "Song to Woody", "w": "109293"}, {"t": "Don't Think Twice, It's All Right", "w": "104326"}, {"t": "Oxford Town", "w": "119466"}, {"t": "Talkin' World War III Blues", "w": "116532"}, {"t": "All Along the Watchtower", "w": "118593"}, {"t": "The Times They Are a-Changin'", "w": "121715"}, {"t": "Blowin' in the Wind", "w": "104808"}, {"t": "I Want You", "w": "120386"}, {"t": "Lay Down Your Weary Tune", "w": "116526"}], "quotes": [], "about_quotes": [{"speaker": "Jake Hanna", "relation": "knows of", "confidence": 1.0, "evidence": "Did you happen to watch the thing the other day, Quincy Jones trying to teach Bruce Springsteen and the poet/singer, what the hell’s his name, Dylan.", "doc_title": "Jake Hanna interviewed by Monk Rowe, Aspen, Colorado, October 11, 1997", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/jake-hanna-interviewed-monk-rowe-aspen-colorado-october-11-1997"}, {"speaker": "James Hunter", "relation": "knows of", "confidence": 1.0, "evidence": "I mean people like Bob Dylan started doing really long ones because... Bob Dylan sort of pretty much broke that with “Like a Rolling Stone”", "doc_title": "James Hunter interviewed by Monk Rowe, Boston, Massachusetts, July 25, 2018", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/james-hunter-interviewed-monk-rowe-boston-massachusetts-july-25-2018"}, {"speaker": "George Benson", "relation": "knows of", "confidence": 0.95, "evidence": "He told me about Bob Dylan. I didn’t know who Bob Dylan was. Didn’t care, but I later found out how important he was.", "doc_title": "George Benson — Smithsonian Jazz Oral History", "collection": "si", "url": "https://amhistory.si.edu/jazz/Benson-George/Benson_George_Transcript.pdf"}, {"speaker": "Chris Parker", "relation": "played with", "confidence": 0.95, "evidence": "Luckily I was not playing a melodic instrument, but I was with him almost four years", "doc_title": "Chris Parker interviewed by Monk Rowe, via Zoom, January 5, 2023", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/chris-parker-interviewed-monk-rowe-zoom-january-5-2023"}, {"speaker": "Mose Allison", "relation": "knows of", "confidence": 0.9, "evidence": "The interviewer mentions Bob Dylan giving Mose Allison a copy of his first album and giving the interviewer a ride, but Mose Allison does not confirm personal interaction or a specific relationship with Dylan in his responses.", "doc_title": "Mose Allison — Smithsonian Jazz Oral History", "collection": "si", "url": "https://americanhistory.si.edu/sites/default/files/file-uploader/Allison_Mose_Interview_Transcription_0.pdf"}, {"speaker": "Hentoff Nat", "relation": "collaborated with", "confidence": 0.9, "evidence": "So I did the notes for the second one. ... Then I did an interview with Dylan for the New Yorker. Then we did our famous, or infamous, Playboy interview", "doc_title": "Hentoff Nat — Smithsonian Jazz Oral History", "collection": "si", "url": "https://americanhistory.si.edu/sites/default/files/file-uploader/Nat_Hentoff_SI-NEA_oral_history%20new%20logo%20%282%29.pdf"}]}