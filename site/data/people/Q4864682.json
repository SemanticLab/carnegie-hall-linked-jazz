c": "James Taylor", "w": "125362"}, {"t": "Mockingbird", "c": "Charlie Foxx", "w": "83502"}, {"t": "Promised Land", "c": "Chuck Berry", "w": "125354"}]}, {"id": "11230", "date": "1974-05-27", "label": "James Taylor, Singer-Songwriter", "venue": "Main Hall", "roles": ["trombone"], "works": [{"t": "Promised Land", "c": "Chuck Berry", "w": "125354"}, {"t": "Mockingbird", "c": "Charlie Foxx", "w": "83502"}, {"t": "Ain't No Song", "c": "David Spinozza", "w": "125363"}, {"t": "You're the One (That I Adore)", "c": "Bobby Bland", "w": "125361"}, {"t": "Rock 'n' Roll is Music Now", "c": "James Taylor", "w": "125362"}]}], "works_created": [], "quotes": [], "about_quotes": [{"speaker": "Randy Brecker", "relation": "collaborated with", "confidence": 0.95, "evidence": "me, Mike and Dave and Ronnie Cuber and Barry Rogers on trombone... we were good at that too... he purposely called me, Mike, Sanborn, Barry, and I think Cuber is on it too.", "doc_title": "Randy Brecker interviewed by Monk Rowe, via Zoom, December 12, 2022", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/randy-brecker-interviewed-monk-rowe-zoom-december-12-2022"}, {"speaker": "Eddie Palmieri", "relation": "collaborated with", "confidence": 0.95, "evidence": "My best musical buddy on the bandstand was Barry Rogers. ... Yes, and doing the arrangements with Barry Rogers.", "doc_title": "Eddie Palmieri — Smithsonian Jazz Oral History", "collection": "si", "url": "https://amhistory.si.edu/jazz/Palmieri-Eddie/Palmieri_Eddie_Interview_Transcription.pdf"}, {"speaker": "Tom Malone", "relation": "in music group with", "confidence": 0.95, "evidence": "And that was the best band I ever played in... Trombones: well myself and Jim Pugh, Dave Taylor, Barry Rogers", "doc_title": "Tom Malone interviewed by Monk Rowe, via Zoom, May 3, 2023", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/tom-malone-interviewed-monk-rowe-zoom-may-3-2023"}, {"speaker": "Dave Liebman", "relation": "in music group with", "confidence": 0.9, "evidence": "This is a funny but interesting band: Randy Brecker, Barry Rogers, Dave Taylor, Tom Malone, you, Sato, Ryo Kawasaki, Francisco Santino on bass, and Harvey Mason on drums.", "doc_title": "Dave Liebman — Smithsonian Jazz Oral History", "collection": "si", "url": "https://amhistory.si.edu/jazz/Liebman-Dave/Liebman_Dave_Transcript.pdf"}]}