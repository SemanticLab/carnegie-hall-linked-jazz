 "23246", "date": "1995-11-20", "label": "Master Class: Leontyne Price", "venue": "Main Hall", "roles": ["speaker"], "works": [{"t": "Selections (unspecified)", "c": null, "w": "104450"}]}, {"id": "11052", "date": "2001-09-30", "label": "A Concert of Remembrance: Honoring the Victims of the Tragedy of September 11", "venue": "Isaac Stern Auditorium / Ronald O. Perelman Stage", "roles": ["soprano"], "works": [{"t": "This Little Light of Mine", "c": "Harry Dixon Loes", "w": "106819"}, {"t": "America the Beautiful", "c": "Samuel Augustus Ward", "w": "7431"}]}], "works_created": [], "quotes": [], "about_quotes": [{"speaker": "Catherine Russell", "relation": "has met", "confidence": 0.95, "evidence": "So we were sitting at the feet of Leontyne Price. And she said, “Hello” you know", "doc_title": "Catherine Russell interviewed by Monk Rowe, Utica, New York, October 26, 2018", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/catherine-russell-interviewed-monk-rowe-utica-new-york-october-26-2018"}, {"speaker": "Jimmy Rowles", "relation": "knows of", "confidence": 0.95, "evidence": "I still think Sarah cuts everybody. ... like Leontyne Price and all that.", "doc_title": "68145_Jimmie Rowles oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/68145/"}, {"speaker": "Byron Stripling", "relation": "knows of", "confidence": 0.9, "evidence": "And so we saw, when I was a kid, Leotyne Price, and we were so proud. It was like when we walked into the hall, my mother and father’s head just went a little bit higher. Because they were saying she’s ours.", "doc_title": "Byron Stripling interviewed by Monk Rowe, Clinton, New York, April 25, 1998 [interview 1 of 2]", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/byron-stripling-interviewed-monk-rowe-clinton-new-york-april-25-1998-interview-1"}, {"speaker": "Joe Bushkin", "relation": "has met", "confidence": 0.9, "evidence": "And then Leontyne Price said she was going to sing, and she wanted to sing “Summertime”... But she was so great, I never forgot it.", "doc_title": "Joe Bushkin interviewed by Monk Rowe, Los Angeles, California, February 15, 1999", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/joe-bushkin-interviewed-monk-rowe-los-angeles-california-february-15-1999"}, {"speaker": "Ed Shaughnessy Part II", "relation": "knows of", "confidence": 0.9, "evidence": "Or to say anything Leontyne Price has done. “Well it’s negated by the fact that she’s not a middle-European.”", "doc_title": "Ed Shaughnessy Part II interviewed by Monk Rowe, Clinton, New York, April 25, 1998 [interview 1 of 2]", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/ed-shaughnessy-part-ii-interviewed-monk-rowe-clinton-new-york-april-25-1998"}, {"speaker": "Big Nick Nicholas", "relation": "knows of", "confidence": 0.9, "evidence": "Leontyne Price when she was married to William Warfield, at the time.", "doc_title": "67619_Big Nick Nicholas oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/67619/"}]}