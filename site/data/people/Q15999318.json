{"qid": "Q15999318", "name": "Shelton Hemphill", "match_basis": "qid", "ch_id": "49201", "ch_uri": "http://data.carnegiehall.org/names/49201", "birth": "1906", "death": "1960", "description": "American musician", "abstract": "Shelton \"Scad\" Hemphill (March 16, 1906 – January 6, 1960) was an American jazz trumpeter whose career lasted from the mid-1920s through the late 1950s. Born in Birmingham, Alabama, Hemphill was still in his teens when he played in the band of Fred Longshaw, which accompanied Bessie Smith on recordings in 1924–25.", "wp_title": "Shelton Hemphill", "image": "img/p/Q15999318.jpg", "is_interviewee": false, "lj_docs": 3, "lj_mentions": 12, "lj_node": "wd:Q15999318", "interviews": [], "concerts": [{"id": "1990", "date": "1939-10-02", "label": "ASCAP American Music Festival", "venue": "Main Hall", "roles": ["trumpet"], "works": [{"t": "(When It's) Sleepy Time Down South", "c": "Leon René", "w": "39351"}, {"t": "Old Man Mose", "c": "Louis Armstrong", "w": "67465"}, {"t": "What Is This Thing Called Swing?", "c": "Louis Armstrong", "w": "67466"}]}, {"id": "33307", "date": "1944-12-19", "label": "Duke Ellington and His Orchestra", "venue": "Main Hall", "roles": ["trumpet"], "works": [{"t": "Selections (unspecified)", "c": null, "w": "104450"}]}, {"id": "5235", "date": "1946-01-04", "label": "Duke Ellington and His Orchestra", "venue": "Main Hall", "roles": ["trumpet"], "works": [{"t": "Selections (unspecified)", "c": null, "w": "104450"}]}, {"id": "24774", "date": "1946-11-23", "label": "Duke Ellington and His Orchestra", "venue": "Main Hall", "roles": ["trumpet"], "works": [{"t": "Selections (unspecified)", "c": null, "w": "104450"}]}, {"id": "43939", "date": "1946-11-24", "label": "Duke Ellington and His Orchestra", "venue": "Main Hall", "roles": ["trumpet"], "works": [{"t": "Selections (unspecified)", "c": null, "w": "104450"}]}, {"id": "30809", "date": "1947-12-26", "label": "Duke Ellington and His Orchestra", "venue": "Main Hall", "roles": ["trumpet"], "works": [{"t": "Selections (unspecified)", "c": null, "w": "104450"}]}, {"id": "30810", "date": "1947-12-27", "label": "Duke Ellington and His Orchestra", "venue": "Main Hall", "roles": ["trumpet"], "works": [{"t": "Selections (unspecified)", "c": null, "w": "104450"}]}, {"id": "18966", "date": "1948-11-13", "label": "Duke Ellington and His Orchestra", "venue": "Main Hall", "roles": ["trumpet"], "works": [{"t": "Tootin' Through the Roof", "c": "Duke Ellington", "w": "31179"}]}], "works_created": [], "quotes": [], "about_quotes": [{"speaker": "Horace Henderson", "relation": "in music group with", "confidence": 1.0, "evidence": "he was in my Wilberforce Collegians band, one of the original, and Shelton stayed with me for quite a spell.", "doc_title": "68514_Horace Henderson oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/68514/"}, {"speaker": "Quentin Jackson", "relation": "in music group with", "confidence": 0.95, "evidence": "Well, the trumpets was Al Killian, Shelton Hemphill, Francis Williams, Shorty Baker, and Ray Nance.", "doc_title": "61539_Butter Jackson oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/61539/"}, {"speaker": "Russell Procope", "relation": "in music group with", "confidence": 0.9, "evidence": "Chick went to Shelton Hemphill... and he got him to play one trumpet... hired the two trumpet players... and he put the three of them together", "doc_title": "68146_Russell Procope oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/68146/"}]}