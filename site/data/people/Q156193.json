702"}], "quotes": [], "about_quotes": [{"speaker": "Hubert Laws", "relation": "played with", "confidence": 0.95, "evidence": "I remember a time sitting – when I played with the Philharmonic, Pierre Boulez was conducting also.", "doc_title": "Hubert Laws — Smithsonian Jazz Oral History", "collection": "si", "url": "https://amhistory.si.edu/jazz/Laws-Hubert/Laws_Hubert_Transcript.pdf"}, {"speaker": "George Russell", "relation": "knows of", "confidence": 0.9, "evidence": "The interviewer mentions Boulez in the context of a roster of composers, but the interviewee (George Russell) does not respond with any personal interaction or relationship details.", "doc_title": "George Russell — Smithsonian Jazz Oral History", "collection": "si", "url": "https://amhistory.si.edu/jazz/Russell-George/Russell_George_Transcript.pdf"}, {"speaker": "Kent Jordan", "relation": "knows of", "confidence": 0.9, "evidence": "Pierre Boulez was leaving the New York Phil when I was in school and he was really trying — at that time you remember — to introduce a lot of new music", "doc_title": "Kent Jordan interviewed by Monk Rowe, Rome, New York, August 22, 2006", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/kent-jordan-interviewed-monk-rowe-rome-new-york-august-22-2006"}, {"speaker": "Schuller Gunther", "relation": "knows of", "confidence": 0.9, "evidence": "I have conducted more contemptible [laughter] – I mean, contemporary music than even Pierre Boulez or any of those people.", "doc_title": "Schuller Gunther — Smithsonian Jazz Oral History", "collection": "si", "url": "https://americanhistory.si.edu/sites/default/files/file-uploader/Gunther_Schuller_SI-NEA_oral_history%20new%20logo%20%282%29.pdf"}, {"speaker": "Mike Wofford", "relation": "knows of", "confidence": 0.9, "evidence": "this, we’re not talking here Pierre Boulez, but on the other hand, in many cases it was wonderful music", "doc_title": "Mike Wofford interviewed by Monk Rowe, San Diego, California, February 13, 1998", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/mike-wofford-interviewed-monk-rowe-san-diego-california-february-13-1998"}]}