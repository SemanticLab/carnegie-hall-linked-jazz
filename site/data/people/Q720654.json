: "40189"}, {"t": "That's John Kirby's Chick", "c": "Charlie Shavers", "w": "55851"}, {"t": "Mop Mop", "c": "Sid Catlett", "w": "57566"}, {"t": "I Love You Truly", "c": "Carrie Jacobs-Bond", "w": "14452"}, {"t": "Pastel Blue", "c": "Charlie Shavers", "w": "44232"}, {"t": "Dawn on the Desert", "c": "Charlie Shavers", "w": "20888"}, {"t": "Mover Over", "c": "Charlie Shavers", "w": "34848"}, {"t": "Otchi chernia (Dark Eyes) (Russian)", "c": "Unknown composer of folk songs", "w": "56323"}]}], "works_created": [{"t": "Mop Mop", "w": "57566"}], "quotes": [], "about_quotes": [{"speaker": "Louie Bellson", "relation": "mentor of", "confidence": 1.0, "evidence": "my two main teachers were Big Sid Catlett and Jo Jones. ... Big Sid and Jo really called me aside and said “look, here’s how you play the brushes... I learned that from Dizzy too.", "doc_title": "Louie Bellson interviewed by Monk Rowe, Sarasota, Florida, April 12, 1996", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/louie-bellson-interviewed-monk-rowe-sarasota-florida-april-12-1996"}, {"speaker": "Jimmie Crawford", "relation": "friend of", "confidence": 1.0, "evidence": "Yeah. Sid was a friend of most people, drummers and whatnot. Sid -- people wanted to be friends of his, period. Yes, we were good friends. Big Sid Catlett.", "doc_title": "63476_Jimmie Crawford oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/63476/"}, {"speaker": "Vincent Pelote", "relation": "knows of", "confidence": 1.0, "evidence": "Wolverine Blues” that he does later with Sid Catlett playing drums behind him man. That’s a kick-ass record.", "doc_title": "Vincent Pelote interviewed by Monk Rowe, Orlando, Florida, February 25, 2017", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/vincent-pelote-interviewed-monk-rowe-orlando-florida-february-25-2017"}, {"speaker": "Nellie Lutcher", "relation": "friend of", "confidence": 1.0, "evidence": "Sid Catlett was a friend of mine and a very marvelous musician", "doc_title": "68426_Nellie Lutcher oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/68426/"}, {"speaker": "Sam Jones", "relation": "knows of", "confidence": 1.0, "evidence": "[INTERVIEWER] Big Sid Catlett ... all those guys on the drums.", "doc_title": "68533_Sam Jones oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/68533/"}, {"speaker": "Bill Coleman", "relation": "played with", "confidence": 0.95, "evidence": "So we asked Sid Catlett to play with us until Mary Lou arrived. That was a unique replacement for a piano, but with Sid on drums, and Al Hall being the solid bass player that he was, the piano was hardly missed", "doc_title": "71542_Bill Coleman autobiographical manuscript", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/71542/"}]}