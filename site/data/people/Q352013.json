specified)", "c": null, "w": "104450"}]}, {"id": "7105", "date": "1945-01-20", "label": "Eddie Condon Jazz Concert", "venue": "Main Hall", "roles": ["trombone"], "works": [{"t": "Selections (unspecified)", "c": null, "w": "104450"}]}, {"id": "17724", "date": "1972-07-02", "label": "Newport Jazz Festival: Count Basie and His Orchestra with Benny Carter and The Swing Masters: Swing Lives", "venue": "Main Hall", "roles": ["trombone"], "works": [{"t": "Honeysuckle Rose", "c": "Fats Waller", "w": "53705"}, {"t": "Doozy", "c": "Benny Carter", "w": "104622"}, {"t": "Jukebox", "c": "Benny Carter", "w": "104624"}, {"t": "Sleep", "c": "Earl Burtnett", "w": "74082"}, {"t": "You Are", "c": "Benny Carter", "w": "74083"}, {"t": "Blues for Beginners", "c": "Benny Carter", "w": "104623"}]}, {"id": "44818", "date": "1972-07-02", "label": "Newport Jazz Festival: Count Basie and His Orchestra with Benny Carter and The Swing Masters: Swing Lives", "venue": "Main Hall", "roles": ["trombone"], "works": [{"t": "Doozy", "c": "Benny Carter", "w": "104622"}, {"t": "Blues for Beginners", "c": "Benny Carter", "w": "104623"}, {"t": "Jukebox", "c": "Benny Carter", "w": "104624"}, {"t": "Honeysuckle Rose", "c": "Fats Waller", "w": "53705"}, {"t": "You Are", "c": "Benny Carter", "w": "74083"}, {"t": "Sleep", "c": "Earl Burtnett", "w": "74082"}]}, {"id": "348", "date": "1972-07-05", "label": "Newport Jazz Festival: Eddie Condon, Lee Wiley, The World's Greatest Jazz Band, and Others", "venue": "Main Hall", "roles": ["trombone"], "works": [{"t": "I Found a New Baby", "c": "Spencer Williams", "w": "42048"}]}, {"id": "44825", "date": "1972-07-05", "label": "Newport Jazz Festival: Eddie Condon, Lee Wiley, The World's Greatest Jazz Band, and Others", "venue": "Main Hall", "roles": ["trombone"], "works": [{"t": "I Found a New Baby", "c": "Spencer Williams", "w": "42048"}]}, {"id": "33297", "date": "1976-02-29", "label": "George Burns, Comedian", "venue": "Main Hall", "roles": ["trombone"], "works": [{"t": "Selections (unspecified)", "c": null, "w": "104450"}]}], "works_created": [], "quotes": [], "about_quotes": [{"speaker": "Ralph Sutton", "relation": "in music group with", "confidence": 1.0, "evidence": "And the band was Benny Morton on trombone... and Bob Haggart and myself.", "doc_title": "Ralph Sutton interviewed by Monk Rowe, Clinton, New York, September 22, 1995", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/ralph-sutton-interviewed-monk-rowe-clinton-new-york-september-22-1995"}, {"speaker": "Eddie Bert", "relation": "mentor of", "confidence": 0.95, "evidence": "I called Benny Morton and I said would you mind giving me lessons? So he said, the only way I could do that, you’re going to have to come to rehearsal and I’ll teach you after rehearsal.", "doc_title": "Eddie Bert interviewed by Monk Rowe, Danbury, Connecticut, November 20, 2001", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/eddie-bert-interviewed-monk-rowe-danbury-connecticut-november-20-2001"}, {"speaker": "Wild Bill Davison", "relation": "in music group with", "confidence": 0.95, "evidence": "[INTERVIEWER] Now, that band was you and then Herbie Hall, on clarinet and, uh Benny Morton - was it - on trombone? [INTERVIEWEE] Yeah -yeah.", "doc_title": "63519_Wild Bill Davison oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/63519/"}, {"speaker": "Teddy Wilson", "relation": "in music group with", "confidence": 0.95, "evidence": "Benny Morton was the one musician straight through the whole period... I had Bill Coleman on trumpet... and then Benny Morton on trombone", "doc_title": "66600_Teddy Wilson oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/66600/"}, {"speaker": "Horace Henderson", "relation": "in music group with", "confidence": 0.95, "evidence": "I got Benny Morton on trombone... we played a lot of theatres... Lena got good money for all of the theatres that we played", "doc_title": "68514_Horace Henderson oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/68514/"}, {"speaker": "Eddie Durham", "relation": "in music group with", "confidence": 0.95, "evidence": "And when I got out, and went to the Benny Morton band... And when I left the Blue Devils, I went to Benny Morton.", "doc_title": "52035_Eddie Durham oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/52035/"}]}