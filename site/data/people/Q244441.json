//rucore.libraries.rutgers.edu/rutgers-lib/67559/"}, {"speaker": "Phil Schaap", "relation": "knows of", "confidence": 0.9, "evidence": "You have Joan Baez, Pete Seeger, Peter, Paul & Mary, Benny Goodman and an unknown folk singer.", "doc_title": "Phil Schaap interviewed by Monk Rowe, Toronto, Canada, January 9, 2003", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/phil-schaap-interviewed-monk-rowe-toronto-canada-january-9-2003"}, {"speaker": "Hentoff Nat", "relation": "has met", "confidence": 0.9, "evidence": "when I was at WMEX, I had Pete Seeger, for example, as a guest on my folk-music program.", "doc_title": "Hentoff Nat — Smithsonian Jazz Oral History", "collection": "si", "url": "https://americanhistory.si.edu/sites/default/files/file-uploader/Nat_Hentoff_SI-NEA_oral_history%20new%20logo%20%282%29.pdf"}, {"speaker": null, "relation": "knows of", "confidence": 0.9, "evidence": "he recorded a bunch with them. I think “We Shall Overcome” ended up on the CD.", "doc_title": "Hamilton College Library|@|Burke Jazz|@|ML3508.5.A83 2001|@|https://www.youtube.com/watch?v=lZyfHceQXNQ", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/hamilton-college-libraryburke-jazzml35085a83"}, {"speaker": "Maxine Sullivan", "relation": "has met", "confidence": 0.9, "evidence": "I didn't know who it was. And so I struck up a conversation with him", "doc_title": "61529_Maxine Sullivan oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/61529/"}]}