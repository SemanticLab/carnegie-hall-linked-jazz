[], "quotes": [], "about_quotes": [{"speaker": "Keith Ingham", "relation": "knows of", "confidence": 1.0, "evidence": "And you ever heard that piano player with Mahalia Jackson? Mildred Falls? You ever seen that Mahalia Jackson “Jazz on a Summer’s Day?”", "doc_title": "Keith Ingham interviewed by Monk Rowe, Chautauqua, New York, September 12, 1997", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/keith-ingham-interviewed-monk-rowe-chautauqua-new-york-september-12-1997"}, {"speaker": "Theodore Saunders", "relation": "collaborated with", "confidence": 0.95, "evidence": "I got the band for her, and she -- and then, this was right at the beginning of the integration of the union, so the union gave her -- oh, let's see, what was it? I think it was a 42-piece band, and I was the conductor for it and everything.", "doc_title": "70399_Theodore _Red_ Saunders oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/70399/"}, {"speaker": "Chico Freeman", "relation": "knows of", "confidence": 0.95, "evidence": "my grandmother was very involved in the church, and she sang in the choir. And she sang with Mahalia Jackson... Mahalia Jackson sang there", "doc_title": "Chico Freeman interviewed by Monk Rowe, New York City, New York, January 13, 2001", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/chico-freeman-interviewed-monk-rowe-new-york-city-new-york-january-13-2001"}, {"speaker": "Big Nick Nicholas", "relation": "knows of", "confidence": 0.95, "evidence": "I began to hear Mahalia Jackson. I bought some of her things because of the sound, you see. I'm very sound conscious.", "doc_title": "67619_Big Nick Nicholas oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/67619/"}, {"speaker": "Vi Redd", "relation": "friend of", "confidence": 0.95, "evidence": "And she would call me, and we got to be good friends, whenever she called or came out to L.A.", "doc_title": "Vi Redd interviewed by Monk Rowe, Los Angeles, California, February 13, 1999", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/vi-redd-interviewed-monk-rowe-los-angeles-california-february-13-1999"}, {"speaker": "John E. Wood", "relation": "knows of", "confidence": 0.9, "evidence": "I first became aware of it when riding on the Fred Street bus and seeing notices on telephone poles and in record shops, placards, that she was going to be here.", "doc_title": "John E. Wood Interview, 1986-06-26", "collection": "tulane", "url": "https://musicrising.tulane.edu/listen/interviews/john-e-wood-1986-06-26/"}]}