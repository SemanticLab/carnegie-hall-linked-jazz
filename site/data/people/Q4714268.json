c_title": "David Brinkley Interview, 1962-01-10", "collection": "tulane", "url": "https://library.search.tulane.edu/permalink/01TUL_INST/4h6sc4/alma9945593582406326"}, {"speaker": "Dorothy Donegan", "relation": "knows of", "confidence": 0.9, "evidence": "I used to like Alec Templeton who had stolen some of Art Tatum’s runs.", "doc_title": "Dorothy Donegan — Smithsonian Jazz Oral History", "collection": "si", "url": "https://amhistory.si.edu/jazz/Donegan-Dorothy/Donegan_Dorothy_Interview_Transcription.pdf"}, {"speaker": "Jeff Riddick", "relation": "played with", "confidence": 0.9, "evidence": "To sit on the same bandstand with Alec Templeton was an honor.", "doc_title": "Jeff Riddick Interview, 1983-08-01", "collection": "tulane", "url": "https://musicrising.tulane.edu/listen/interviews/jeff-riddick-1983-08-01/"}]}