: "19101", "date": "1967-03-26", "label": "Jazz at the Philharmonic", "venue": "Main Hall", "roles": ["alto_saxophone", "clarinet"], "works": [{"t": "Selections (unspecified)", "c": null, "w": "104450"}, {"t": "Salomé", "c": "Duke Ellington", "w": "117359"}, {"t": "A Chromatic Love Affair", "c": "Duke Ellington", "w": "117360"}, {"t": "Rue Bleue", "c": "Duke Ellington", "w": "67254"}, {"t": "Blood Count", "c": "Billy Strayhorn", "w": "33766"}]}, {"id": "18987", "date": "1968-04-04", "label": "Duke Ellington in His Concert of Sacred Music", "venue": "Main Hall", "roles": ["alto_saxophone", "clarinet"], "works": [{"t": "Selections (unspecified)", "c": null, "w": "104450"}]}, {"id": "26917", "date": "1974-04-26", "label": "The New York Jazz Repertory Company: Duke Ellington 75th Birthday Salute", "venue": "Main Hall", "roles": ["alto_saxophone"], "works": [{"t": "Black, Brown and Beige: Come Sunday", "c": "Duke Ellington", "w": "21609"}, {"t": "In a Sentimental Mood", "c": "Duke Ellington", "w": "45984"}, {"t": "I Got It Bad (and That Ain't Good)", "c": "Duke Ellington", "w": "34237"}]}], "works_created": [], "quotes": [], "about_quotes": [{"speaker": "Phil Schaap", "relation": "friend of", "confidence": 1.0, "evidence": "I knew Russell Procope well... I would say Russell Procope was the first close friend, extra family, extra father, to die", "doc_title": "Phil Schaap interviewed by Monk Rowe, Toronto, Canada, January 9, 2003", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/phil-schaap-interviewed-monk-rowe-toronto-canada-january-9-2003"}, {"speaker": "Jean Bach", "relation": "in music group with", "confidence": 0.95, "evidence": "The cast was Russell Procope on saxophone and Buster Bailey on clarinet. Billy Kyle was the piano player, and Charlie Shavers wrote the arrangements and played trumpet, and Kirby was the bassist.", "doc_title": "Jean Bach interviewed by Monk Rowe, New York City, New York, October 18, 1995", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/jean-bach-interviewed-monk-rowe-new-york-city-new-york-october-18-1995"}, {"speaker": "Louie Bellson", "relation": "in music group with", "confidence": 0.95, "evidence": "I had to pinch myself many times... Russell Procope... You were with Duke from ’51 through early ’53... He knew what to do... learn to write for... Russell Procope.", "doc_title": "Louie Bellson — Smithsonian Jazz Oral History", "collection": "si", "url": "https://amhistory.si.edu/jazz/Bellson-Louie/Bellson_Louie_Transcript.pdf"}, {"speaker": "Walter P. Thomas", "relation": "in music group with", "confidence": 0.95, "evidence": "I know Procope and I played alto, and Procope played clarinet... He got ahold of Procope and Garland...", "doc_title": "68429_Walter P. Thomas oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/68429/"}, {"speaker": "Patricia Willard", "relation": "in music group with", "confidence": 0.95, "evidence": "me and Procope, we got in a cab... featuring... Russell Procope... [INTERVIEWEE] Uh huh.", "doc_title": "61531_Juan Tizol oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/61531/"}, {"speaker": "Budd Johnson", "relation": "in music group with", "confidence": 0.95, "evidence": "My first close, close experience was -- with him was when I joined the John Kirby band.", "doc_title": "68515_Budd Johnson oral history interview", "collection": "rutgers", "url": "https://rucore.libraries.rutgers.edu/rutgers-lib/68515/"}]}