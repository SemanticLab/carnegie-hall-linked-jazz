"}]}, {"id": "807", "date": "1994-09-27", "label": "Illinois Jacquet: \"Jammin' the Blues\" 50th Anniversary Celebration", "venue": "Main Hall", "roles": ["vocalist"], "works": [{"t": "Selections (unspecified)", "c": null, "w": "104450"}]}], "works_created": [{"t": "Hallelujah, I love her so", "w": "28067"}, {"t": "Sweet Sixteen Bars", "w": "104819"}, {"t": "What'd I Say?", "w": "74103"}], "quotes": [], "about_quotes": [{"speaker": "Paquito D'Rivera", "relation": "knows of", "confidence": 1.0, "evidence": "The music that we play by Mancini was [imitates rhythm] that big band type of sound was on old movies, I know that, was made famous by Ray Charles, it was a big hit in Havana in 1965", "doc_title": "Paquito D'Rivera — Smithsonian Jazz Oral History", "collection": "si", "url": "https://amhistory.si.edu/jazz/Drivera-Paquito/D'Rivera_Paquito_%20Interview_Transcription.pdf"}, {"speaker": "Wendell Brunious", "relation": "knows of", "confidence": 1.0, "evidence": "His daddy wrote a lot of stuff with Ray Charles, Reynolds Richard. He wrote “I’ve Got a Woman” and a few things like that.", "doc_title": "Wendell Brunious interviewed by Monk Rowe, Scottsdale, Arizona, April 16, 2000 [interview 2 of 2]", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/wendell-brunious-interviewed-monk-rowe-scottsdale-arizona-april-16-2000"}, {"speaker": "Wendy Oxenhorn", "relation": "knows of", "confidence": 1.0, "evidence": "I was big into Ray Charles, too. I remember, when I was 10, wanting to be a Raylette more than anything.", "doc_title": "Wendy Oxenhorn — Smithsonian Jazz Oral History", "collection": "si", "url": "https://americanhistory.si.edu/sites/default/files/file-uploader/Wendy-Oxenhorn-Transcription-2020.pdf"}, {"speaker": "Ben Sidran", "relation": "knows of", "confidence": 1.0, "evidence": "You know that’s the one Ray Charles played on “What’d I Say” that just blew everybody’s mind.", "doc_title": "Ben Sidran interviewed by Monk Rowe, via Zoom, November 15, 2023", "collection": "hamilton", "url": "https://litsdigital.hamilton.edu/collections/object/ben-sidran-interviewed-monk-rowe-zoom-november-15-2023"}, {"speaker": "Ramsey Lewis", "relation": "influenced by", "confidence": 0.95, "evidence": "Ray Charles was an influence. ... I bought all of his records, because I think he touched me in that place where, when I was playing in our church ... He touched something there.", "doc_title": "Ramsey Lewis — Smithsonian Jazz Oral History", "collection": "si", "url": "https://amhistory.si.edu/jazz/Lewis-Ramsey/Lewis_Ramsey_Interview_Transcription.pdf"}, {"speaker": "David N. Baker", "relation": "knows of", "confidence": 0.95, "evidence": "You probably would have been listening to Count Basie. And a little later, by the 1940s, Ruth Brown, Ray Charles, Dinah Washington, and Nat – of course Nat “King” Cole.", "doc_title": "David N. Baker — Smithsonian Jazz Oral History", "collection": "si", "url": "https://americanhistory.si.edu/sites/default/files/file-uploader/David%20N.%20Baker%20SI-NEA%20oral%20history%20%282%29.pdf"}]}